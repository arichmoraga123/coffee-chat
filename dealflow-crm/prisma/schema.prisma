// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  passwordHash        String
  role                String   @default("USER")
  drillStreak         Int      @default(0)
  lastDrillDay        String? // YYYY-MM-DD (UTC)
  xp                  Int      @default(0)
  weeklyXP            Int      @default(0)
  recruitingTarget    String[] @default([])
  /** Primary career paths for filtering prep (DB column legacy name `preferredTracks`). */
  careerTracks        String[] @default([]) @map("preferredTracks")
  schoolId            String?
  eduEmail            String?
  eduVerified         Boolean  @default(false)
  eduVerificationToken   String?
  eduVerificationExpires DateTime?
  contributionXP    Int      @default(0)
  bio                 String?
  referralCode        String?  @unique
  targetFirms         String[] @default([])
  dailyGoal           Int      @default(5)
  onboardingDone      Boolean  @default(false)
  accountActive         Boolean  @default(true)
  lastActiveAt          DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  school              School?  @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  clubMemberships     ClubMember[]
  compData            CompData[]
  compDataUpvotes     CompDataUpvote[]
  referralsGiven      Referral[] @relation("Referrer")
  referralsReceived   Referral[] @relation("Referee")
  clubPostsAuthored   ClubPost[]       @relation("ClubPostAuthor")
  clubAnnouncementsAuthored ClubAnnouncement[] @relation("ClubAnnouncementAuthor")
  contacts            Contact[]
  firms               Firm[]
  interactions        Interaction[]
  opportunities       Opportunity[]
  tasks               Task[]
  questionProgress    UserQuestionProgress[]
  resourceBookmarks   ResourceBookmark[]
  timelinesSubmitted  FirmTimeline[]         @relation("TimelineSubmitter")
  timelineVotes       FirmTimelineVote[]
  dailyDrillLogs      DailyDrillLog[]
  leaderboardEntry    LeaderboardEntry?
  recruitingEvents    RecruitingEvent[]
  submittedQuestions  Question[]             @relation("QuestionSubmitter")
  mockInterviewSessions      MockInterviewSession[]
  mockInterviewQuestions     MockInterviewQuestion[] @relation("MockInterviewQuestionSubmitter")
  interviewDebriefs          InterviewDebrief[]
  templateUpvotes            TemplateUpvote[]
  dealBookmarks              DealBookmark[]
  vaultDocumentUpvotes       VaultDocumentUpvote[]
  studyGroupMembers          StudyGroupMember[]
  studyGroupsCreated         StudyGroup[]           @relation("StudyGroupCreator")
  studyGroupMessages         StudyGroupMessage[]
  offerComparisons           OfferComparison[]
  apiUsageLogs               ApiUsageLog[]
  contentReports             ContentReport[]        @relation("ContentReportReporter")
  calendarIntegrations       CalendarIntegration[]
  resumeReviews              ResumeReview[]
  caseCompetitions           CaseCompetition[]
  recruitingCalendarVotes    RecruitingCalendarVote[]
  stockPitches                 StockPitch[]
}

model Question {
  id             String                 @id @default(cuid())
  question       String
  answer         String
  keywords       String[]               @default([])
  category       String
  subcategory    String?
  difficulty     String
  tags           String[]
  /** Empty = relevant to all tracks. Otherwise show only if user selected a matching track. */
  careerTracks   String[]               @default([])
  source         String?
  status         String                 @default("active") // active | pending | rejected
  dedupeKey      String?                @unique
  submittedById  String?
  schoolId       String?
  scope          String                 @default("global") // global | school | club
  upvotes        Int                    @default(0)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @default(now()) @updatedAt
  userProgress   UserQuestionProgress[]
  submitter      User?                  @relation("QuestionSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  school         School?                @relation(fields: [schoolId], references: [id], onDelete: SetNull)
}

model UserQuestionProgress {
  id         String   @id @default(cuid())
  userId     String
  questionId String
  status     String // "known" | "review" | "unseen"
  lastSeen   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
}

model DailyDrillLog {
  id                  String @id @default(cuid())
  userId              String
  date                String // YYYY-MM-DD UTC
  questionsAnswered   Int
  correct             Int
  xpEarned            Int
  user                User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model LeaderboardEntry {
  id       String @id @default(cuid())
  userId   String @unique
  username String
  weeklyXP Int    @default(0)
  totalXP  Int    @default(0)
  streak   Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NewsArticle {
  id          String   @id @default(cuid())
  title       String
  description String?
  url         String   @unique
  source      String
  publishedAt DateTime
  category    String // M&A | PE/VC | Markets | Banking
  imageUrl    String?
  cachedAt    DateTime @default(now())
}

model RecruitingEvent {
  id                    String   @id @default(cuid())
  userId                String
  title                 String
  date                  DateTime
  type                  String // coffee_chat | deadline | interview | networking | other
  firmName              String?
  notes                 String?
  googleCalendarEventId   String?
  outlookCalendarEventId String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ResourceBookmark {
  id           String @id @default(cuid())
  userId       String
  resourceSlug String
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceSlug])
}

model FirmTimeline {
  id               String    @id @default(cuid())
  firmName         String
  firmType         String // BB, EB, MM, PE, VC
  role             String
  applicationOpen  DateTime?
  applicationClose DateTime?
  firstRound       DateTime?
  finalRound       DateTime?
  offerDate        DateTime?
  year             Int
  notes            String?
  careerTracks     String[]  @default([])
  schoolId         String?
  scope            String    @default("global") // global | school | club
  submittedBy      String?
  verified         Boolean   @default(false)
  upvotes          Int       @default(0)
  createdAt        DateTime  @default(now())
  submitter        User?     @relation("TimelineSubmitter", fields: [submittedBy], references: [id], onDelete: SetNull)
  school           School?   @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  votes            FirmTimelineVote[]
}

model FirmTimelineVote {
  id         String       @id @default(cuid())
  userId     String
  timelineId String
  timeline   FirmTimeline @relation(fields: [timelineId], references: [id], onDelete: Cascade)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, timelineId])
}

enum FirmType {
  IB
  PE
  GE
  VC
  HF
  CONSULTING
  CORPORATE
  OTHER
}

enum RecruitingCategory {
  IB
  PE
  GE
  VC
  HF
}

enum ReferralProbability {
  LOW
  MEDIUM
  HIGH
}

enum InteractionType {
  COFFEE_CHAT
  CALL
  EMAIL
  LINKEDIN
  IN_PERSON
}

enum OpportunityStage {
  TARGET
  NETWORKING
  APPLIED
  FIRST_ROUND
  TECHNICAL
  SUPERDAY
  OFFER
  REJECTED
}

enum Priority {
  HIGH
  MEDIUM
  LOW
}

enum TaskType {
  FOLLOW_UP
  THANK_YOU
  CHECK_IN
  APPLY
}

enum TaskStatus {
  PENDING
  COMPLETED
}

model Contact {
  id                   String              @id @default(cuid())
  fullName             String
  email                String
  phone                String?
  linkedinUrl          String?
  group                String
  title                String
  location             String
  school               String
  recruitingCategory   RecruitingCategory
  relationshipStrength Int                 @default(1)
  referralProbability  ReferralProbability
  notes                String              @default("")
  lastInteractionDate  DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  firmId               String
  userId               String

  undergradSchool   String?
  gradSchool        String?
  graduationYear    Int?
  hometown          String?
  previousFirms     String[] @default([])
  careerPath        String?

  clubs       String[] @default([])
  sports      String[] @default([])
  greekLife   String?

  howWeMet            String?
  referredBy          String?
  mutualConnections   String[] @default([])
  warmthScore         String   @default("COLD") // COLD | WARM | HOT | ADVOCATE

  hiringTimeline    String?
  whatTheyLookFor   String?
  referralPotential String?
  openRoles         String?

  notableDeals String[] @default([])

  firm                 Firm                @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user                 User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  interactions         Interaction[]
  tasks                Task[]
  opportunities        OpportunityContact[]

  @@unique([userId, email])
}

model Firm {
  id              String        @id @default(cuid())
  name            String
  type            FirmType?
  location        String
  aum             String?
  focus           String
  recruitingNotes String        @default("")
  createdAt       DateTime      @default(now())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts        Contact[]
  opportunities   Opportunity[]

  @@unique([userId, name])
}

model Interaction {
  id                 String          @id @default(cuid())
  date               DateTime
  type               InteractionType
  notes              String?
  adviceGiven        String?
  actionItems        String[]        @default([])
  actionItemsChecked Int[]           @default([])
  personalDetails    String?
  firmInsights       String?
  redFlags           String?
  followUpDate             DateTime?
  googleCalendarEventId    String?
  outlookCalendarEventId   String?
  createdAt               DateTime        @default(now())
  contactId               String
  userId                  String
  contact                 Contact         @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user                    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Opportunity {
  id                  String               @id @default(cuid())
  role                String
  stage               OpportunityStage     @default(TARGET)
  priority            Priority             @default(MEDIUM)
  notes               String               @default("")
  applicationDeadline      DateTime?
  googleCalendarEventId    String?
  outlookCalendarEventId   String?
  contactName               String               @default("")
  createdAt                 DateTime             @default(now())
  firmId                    String
  userId                    String
  firm       Firm                 @relation(fields: [firmId], references: [id], onDelete: Cascade)
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts   OpportunityContact[]
}

model OpportunityContact {
  opportunityId String
  contactId     String
  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  contact       Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([opportunityId, contactId])
}

model Task {
  id        String     @id @default(cuid())
  dueDate   DateTime
  taskType  TaskType
  status    TaskStatus @default(PENDING)
  notes     String     @default("")
  contactId String
  userId    String
  contact   Contact    @relation(fields: [contactId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- Recruiting Hub: shared question bank, private sessions ---
model MockInterviewQuestion {
  id            String   @id @default(cuid())
  question      String
  category      String
  bankSource    String
  year          Int?
  difficulty    String
  modelAnswer   String?
  tips          String?
  careerTracks  String[] @default([])
  upvotes       Int      @default(0)
  submittedById String?
  status        String   @default("active")
  dedupeKey     String?  @unique
  createdAt     DateTime @default(now())
  submitter     User?    @relation("MockInterviewQuestionSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)

  @@index([bankSource, status])
  @@index([status])
}

model MockInterviewSession {
  id          String   @id @default(cuid())
  userId      String
  mode        String
  bankFilter  String?
  questions   String[]
  scores      Json
  duration    Int
  aiSummary   String?
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model InterviewDebrief {
  id               String   @id @default(cuid())
  userId           String
  firmName         String
  round            String
  date             DateTime
  questionsAsked   String[]
  myAnswers        String?
  whatWentWell     String?
  improvements     String?
  outcome          String?
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, date])
}

// --- Shared firm research wiki ---
model FirmResearch {
  id                String   @id @default(cuid())
  firmName          String   @unique
  firmType          String
  aum               String?
  founded           Int?
  headquarters      String?
  description       String?
  investmentFocus   String?
  dealSize          String?
  notableDeals      String[] @default([])
  whatTheyLookFor   String?
  hiringTimeline    String?
  interviewProcess  String?
  culture           String?
  msuAlumni         String[] @default([])
  websiteUrl        String?
  linkedinUrl       String?
  lastUpdated       DateTime @default(now())
  updatedById       String?
}

// --- Shared email templates ---
model EmailTemplate {
  id              String   @id @default(cuid())
  title           String
  category        String
  subject         String?
  body            String
  tags            String[] @default([])
  upvotes         Int      @default(0)
  submittedById   String?
  isOfficial      Boolean  @default(false)
  dedupeKey       String?  @unique
  archived        Boolean  @default(false)
  createdAt       DateTime @default(now())
  upvotedBy       TemplateUpvote[]

  @@index([archived])
}

model TemplateUpvote {
  id         String        @id @default(cuid())
  userId     String
  templateId String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  template   EmailTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([userId, templateId])
}

// --- Shared deals, private bookmarks ---
model Deal {
  id          String         @id @default(cuid())
  title       String         @unique
  acquirer    String?
  target      String?
  dealValue   String?
  dealType    String
  vertical    String?
  sector      String?
  summary     String
  keyThesis   String?
  risks       String?
  sourceUrl   String?
  announcedAt DateTime
  status      String         @default("draft") // draft | published
  careerTracks String[]      @default([])
  dedupeKey   String?        @unique
  createdAt   DateTime       @default(now())
  bookmarks   DealBookmark[]

  @@index([status])
}

model ConsultingCase {
  id           String   @id @default(cuid())
  title        String
  type         String
  difficulty   String
  prompt       String   @db.Text
  framework    String?  @db.Text
  sampleAnswer String?  @db.Text
  firmSource   String?
  isShared     Boolean  @default(true)
  dedupeKey    String?  @unique
  careerTracks String[] @default(["Consulting"])
  createdAt    DateTime @default(now())
}

model StockPitch {
  id               String   @id @default(cuid())
  userId           String
  companyName      String
  overview         String   @db.Text
  thesisBullets    String[] @default([])
  currentPrice     String?
  targetPrice      String?
  catalysts        String[] @default([])
  risks            String[] @default([])
  recommendation   String
  deckOutline      String?  @db.Text
  sharedToGroupId  String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyGroup       StudyGroup? @relation(fields: [sharedToGroupId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sharedToGroupId])
}

model DealBookmark {
  id     String @id @default(cuid())
  userId String
  dealId String
  notes  String?
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([userId, dealId])
}

// --- Shared vault (anonymized metadata); submitter id stored for moderation ---
model VaultDocument {
  id              String   @id @default(cuid())
  type            String
  targetFirm      String?
  targetRole      String?
  outcome         String?
  year            Int?
  school          String?
  fileUrl         String?
  notes           String?
  upvotes         Int      @default(0)
  submittedById   String?
  dedupeKey       String?  @unique
  status          String   @default("active") // active | pending | rejected
  createdAt       DateTime @default(now())
  upvotedBy       VaultDocumentUpvote[]

  @@index([status])
}

model VaultDocumentUpvote {
  id         String        @id @default(cuid())
  userId     String
  documentId String
  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   VaultDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
}

// --- Study groups: visible to members only ---
model StudyGroup {
  id           String              @id @default(cuid())
  name         String
  createdBy    String
  createdAt    DateTime            @default(now())
  creator      User                @relation("StudyGroupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members      StudyGroupMember[]
  messages     StudyGroupMessage[]
  sharedPitches StockPitch[]
}

model StudyGroupMember {
  id      String     @id @default(cuid())
  groupId String
  userId  String
  role    String     @default("member")
  group   StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model StudyGroupMessage {
  id        String     @id @default(cuid())
  groupId   String
  userId    String
  body      String
  createdAt DateTime   @default(now())
  group     StudyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([groupId, createdAt])
}

// --- Private offer comparison ---
model OfferComparison {
  id         String   @id @default(cuid())
  userId     String
  offers     Json
  aiAnalysis String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiUsageLog {
  id           String   @id @default(cuid())
  userId       String
  feature      String
  inputTokens  Int
  outputTokens Int
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature])
}

model ContentReport {
  id         String   @id @default(cuid())
  reporterId String
  targetType String
  targetId   String
  reason     String
  status     String   @default("pending") // pending | reviewed | dismissed
  createdAt  DateTime @default(now())
  reporter   User     @relation("ContentReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([targetType, targetId])
}

// --- External calendars (Google + Outlook) — one row per provider per user ---
model CalendarIntegration {
  id           String    @id @default(cuid())
  userId       String
  provider     String // "google" | "outlook"
  accessToken  String    @db.Text
  refreshToken String    @db.Text
  expiresAt    DateTime
  calendarId   String?
  syncEnabled  Boolean   @default(true)
  lastSynced   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
}

// --- AI resume review (last 5 per user enforced in app) ---
model ResumeReview {
  id        String   @id @default(cuid())
  userId    String
  fileName  String
  score     Int
  feedback  Json
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// --- Case competitions (private) ---
model CaseCompetition {
  id            String   @id @default(cuid())
  userId        String
  name          String
  organizer     String?
  date          DateTime
  teamMembers   String[] @default([])
  role          String?
  topic         String?
  result        String?
  description   String?
  driveLink     String?
  skills        String[] @default([])
  addToResume   Boolean  @default(false)
  resumeBullets String[] @default([])
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Shared recruiting season calendar (crowdsourced) ---
model RecruitingCalendarEvent {
  id          String   @id @default(cuid())
  title       String
  firmName    String?
  vertical    String?
  eventType   String
  date        DateTime
  endDate     DateTime?
  year        Int
  isRecurring Boolean  @default(false)
  notes       String?
  sourceUrl   String?
  submittedBy String?
  verified    Boolean  @default(false)
  upvotes     Int       @default(0)
  dedupeKey   String?   @unique
  createdAt   DateTime  @default(now())
  votes       RecruitingCalendarVote[]

  @@index([year, date])
  @@index([vertical])
}

model RecruitingCalendarVote {
  id      String                  @id @default(cuid())
  userId  String
  eventId String
  user    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  event   RecruitingCalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
}

// --- Prospect: multi-school network ---
model School {
  id           String         @id @default(cuid())
  name         String         @unique
  shortName    String
  domain       String         @unique
  location     String?
  country      String         @default("US")
  type         String         @default("semi-target") // target | semi-target | non-target
  logoUrl      String?
  isVerified   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  members      User[]
  clubs        Club[]
  questions    Question[]
  timelines    FirmTimeline[]
  compData     CompData[]
  alumni       SchoolAlumni[]
}

model Club {
  id             String               @id @default(cuid())
  schoolId       String
  name           String
  type           String
  description    String?
  logoUrl        String?
  isVerified     Boolean              @default(false)
  isPublic       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  school         School               @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  members        ClubMember[]
  posts          ClubPost[]
  projects       ClubProject[]
  events         ClubEvent[]
  announcements  ClubAnnouncement[]
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  subscriptionStatus   String?
  trialEndsAt          DateTime?
  currentPeriodEnd     DateTime?

  @@unique([schoolId, name])
}

model ClubMember {
  id       String   @id @default(cuid())
  clubId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())
  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
}

model ClubPost {
  id        String    @id @default(cuid())
  clubId    String
  authorId  String
  title     String
  content   String    @db.Text
  type      String
  dueDate   DateTime?
  driveLink String?
  isPinned  Boolean   @default(false)
  readBy    String[]  @default([])
  createdAt DateTime  @default(now())
  club      Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author    User      @relation("ClubPostAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

model ClubProject {
  id           String            @id @default(cuid())
  clubId       String
  title        String
  description  String?           @db.Text
  dueDate      DateTime?
  memberIds    String[]          @default([])
  driveLink    String?
  status       String            @default("active")
  createdAt    DateTime          @default(now())
  club         Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  deliverables ClubDeliverable[]

  @@index([clubId])
}

model ClubDeliverable {
  id          String      @id @default(cuid())
  projectId   String
  title       String
  assignedTo  String[]    @default([])
  dueDate     DateTime?
  status      String      @default("pending")
  driveLink   String?
  project     ClubProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ClubEvent {
  id            String   @id @default(cuid())
  clubId        String
  title         String
  description   String?  @db.Text
  date          DateTime
  location      String?
  type          String
  rsvpIds       String[] @default([])
  capacity      Int?
  materialsLink String?
  createdAt     DateTime @default(now())
  club          Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, date])
}

model ClubAnnouncement {
  id        String   @id @default(cuid())
  clubId    String
  authorId  String
  title     String
  body      String   @db.Text
  isPinned  Boolean  @default(false)
  readBy    String[] @default([])
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  author    User     @relation("ClubAnnouncementAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([clubId, createdAt])
}

model CompData {
  id             String           @id @default(cuid())
  userId         String
  schoolId       String?
  firmName       String
  role           String
  vertical       String
  officeLocation String?
  baseComp       Int?
  signingBonus   Int?
  yearEndBonus   Int?
  totalComp      Int?
  year           Int
  anonymous      Boolean          @default(true)
  verified       Boolean          @default(false)
  upvotes        Int              @default(0)
  createdAt      DateTime         @default(now())
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  school         School?          @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  upvotedBy      CompDataUpvote[]

  @@index([year, firmName])
}

model CompDataUpvote {
  id     String   @id @default(cuid())
  userId String
  compId String
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  comp   CompData @relation(fields: [compId], references: [id], onDelete: Cascade)

  @@unique([userId, compId])
}

model SchoolAlumni {
  id           String   @id @default(cuid())
  schoolId     String
  firmName     String
  role         String
  vertical     String
  gradYear     Int?
  linkedinUrl  String?
  openToChat   Boolean  @default(false)
  anonymous    Boolean  @default(false)
  submittedBy  String?
  verified     Boolean  @default(false)
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@index([schoolId, firmName])
}

model Referral {
  id         String   @id @default(cuid())
  referrerId String
  refereeId  String?
  code       String   @unique
  status     String   @default("pending")
  xpAwarded  Boolean  @default(false)
  createdAt  DateTime @default(now())
  referrer   User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referee    User?    @relation("Referee", fields: [refereeId], references: [id], onDelete: SetNull)
}
